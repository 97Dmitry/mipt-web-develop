          }
        },
        {
          "name": "DELETE /catalog/categories/{id}",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "DELETE",
            "url": {
              "raw": "{{adminPanelUrl}}/catalog/categories/{{categoryId}}",
              "host": ["{{adminPanelUrl}}"],
              "path": ["catalog", "categories", "{{categoryId}}"]
            },
            "description": "Удаление категории через BFF. Успех 204. Ошибка 409: CATEGORY_IN_USE. Ошибки: 401, 404."
          }
        }
      ]
    },
    {
      "name": "Orders BFF",
      "item": [
        {
          "name": "GET /orders",
